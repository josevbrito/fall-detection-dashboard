# .env.example — copie para .env.local:  cp .env.example .env.local
#
# URL do ThingsBoard (HTTP/REST).
#   - No notebook servidor (mesmo host):   http://localhost:8090
#   - Em outra máquina na LAN:             http://192.168.100.86:8090
TB_URL=http://localhost:8090

# Credenciais do tenant admin (as mesmas que o provision_devices.py usa).
TB_TENANT_EMAIL=fall-tenant@thingsboard.org
TB_TENANT_PASSWORD=tenant2026
